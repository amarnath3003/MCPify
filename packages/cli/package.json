{
  "name": "mcpify-cli",
  "version": "1.0.4",
  "type": "module",
  "bin": {
    "mcpify": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "bundle": "tsup",
    "typecheck": "tsc --noEmit",
    "prepack": "tsup",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@apidevtools/swagger-parser": "^10.1.0",
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "ora": "^8.0.0",
    "prettier": "^3.2.0",
    "ts-morph": "^21.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@mcpify/ai-enhancer": "*",
    "@mcpify/backend-analyzer": "*",
    "@mcpify/event-analyzer": "*",
    "@mcpify/frontend-analyzer": "*",
    "@mcpify/mcp-generator": "*",
    "@mcpify/permissions": "*",
    "@mcpify/schema-engine": "*",
    "@mcpify/security": "*",
    "@mcpify/sync-engine": "*",
    "@mcpify/workflow-engine": "*",
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "description": "Compile application code into a runnable Model Context Protocol (MCP) server — and auto-register it with Codex, Claude, and VS Code.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agents",
    "codex",
    "claude",
    "code-generation",
    "cli"
  ],
  "homepage": "https://github.com/amarnath3003/MCPify#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amarnath3003/MCPify.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/amarnath3003/MCPify/issues"
  }
